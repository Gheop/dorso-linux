#: dorso/onboarding.py:68
msgid "Welcome to Dorso"
msgstr "Bem-vindo ao Dorso"

#: dorso/onboarding.py:73
msgid ""
"Dorso monitors your posture via webcam\n"
"and shows a <b>red glow</b> when you slouch.\n"
"\n"
"The overlay is transparent and doesn't\n"
"interfere with mouse or keyboard."
msgstr ""
"O Dorso monitora sua postura pela webcam\n"
"e exibe um <b>brilho vermelho</b> quando você se curva.\n"
"\n"
"A sobreposição é transparente e não\n"
"interfere com o mouse nem o teclado."

#: dorso/onboarding.py:86
msgid "Get started →"
msgstr "Começar →"

#: dorso/onboarding.py:106
msgid "Calibration"
msgstr "Calibração"

#: dorso/onboarding.py:111
msgid ""
"Sit <b>up straight</b> in your best posture.\n"
"Make sure you are visible in the preview."
msgstr ""
"Sente-se <b>bem ereto</b> na sua melhor postura.\n"
"Verifique se você está visível na pré-visualização."

#: dorso/onboarding.py:135 dorso/calibration.py:60
msgid "Calibrate"
msgstr "Calibrar"

#: dorso/onboarding.py:141 dorso/calibration.py:65
msgid "Cancel"
msgstr "Cancelar"

#: dorso/onboarding.py:160
msgid "All set!"
msgstr "Tudo pronto!"

#: dorso/onboarding.py:165
msgid ""
"Dorso is now running in the background.\n"
"\n"
"• <b>Tray icon</b> — real-time posture status\n"
"• <b>Settings</b> — warning mode, color, sensitivity\n"
"• <b>Analytics</b> — daily score and history"
msgstr ""
"O Dorso está rodando em segundo plano.\n"
"\n"
"• <b>Ícone da bandeja</b> — estado da postura em tempo real\n"
"• <b>Configurações</b> — modo de alerta, cor, sensibilidade\n"
"• <b>Análises</b> — pontuação diária e histórico"

#: dorso/onboarding.py:178
msgid "Start"
msgstr "Iniciar"

#: dorso/onboarding.py:252
msgid ""
"<b>Camera not found</b>\n"
"\n"
"Make sure your webcam is plugged in\n"
"and try again."
msgstr ""
"<b>Câmera não encontrada</b>\n"
"\n"
"Verifique se sua webcam está conectada\n"
"e tente novamente."

#: dorso/onboarding.py:265
msgid ""
"<big><b>Calibrating…</b></big>\n"
"Stay still for a few seconds."
msgstr ""
"<big><b>Calibrando…</b></big>\n"
"Fique parado por alguns segundos."

#: dorso/onboarding.py:282
msgid ""
"<b>Calibration failed</b>\n"
"\n"
"Make sure you are clearly visible to the camera\n"
"and try again."
msgstr ""
"<b>Calibração falhou</b>\n"
"\n"
"Verifique se você está claramente visível para a câmera\n"
"e tente novamente."

#: dorso/calibration.py:32
msgid "Dorso — Calibration"
msgstr "Dorso — Calibração"

#: dorso/calibration.py:46
msgid ""
"<big><b>Posture calibration</b></big>\n"
"\n"
"Sit up straight in your best\n"
"posture, then click\n"
"<b>Calibrate</b>."
msgstr ""
"<big><b>Calibração de postura</b></big>\n"
"\n"
"Sente-se bem ereto na sua\n"
"melhor postura, depois clique em\n"
"<b>Calibrar</b>."

#: dorso/calibration.py:78
msgid ""
"<big><b>Calibrating…</b></big>\n"
"\n"
"Stay still for a few\n"
"seconds."
msgstr ""
"<big><b>Calibrando…</b></big>\n"
"\n"
"Fique parado por alguns\n"
"segundos."

