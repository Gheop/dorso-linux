#: dorso/onboarding.py:68
msgid "Welcome to Dorso"
msgstr "Bienvenue sur Dorso"

#: dorso/onboarding.py:73
msgid ""
"Dorso monitors your posture via webcam\n"
"and shows a <b>red glow</b> when you slouch.\n"
"\n"
"The overlay is transparent and doesn't\n"
"interfere with mouse or keyboard."
msgstr ""
"Dorso surveille votre posture via la webcam\n"
"et affiche un <b>halo rouge</b> quand vous vous voûtez.\n"
"\n"
"L'overlay est transparent et ne gêne ni\n"
"la souris ni le clavier."

#: dorso/onboarding.py:86
msgid "Get started →"
msgstr "Commencer →"

#: dorso/onboarding.py:106
msgid "Calibration"
msgstr "Calibration"

#: dorso/onboarding.py:111
msgid ""
"Sit <b>up straight</b> in your best posture.\n"
"Make sure you are visible in the preview."
msgstr ""
"Asseyez-vous <b>bien droit</b> dans votre meilleure posture.\n"
"Vérifiez que vous êtes visible dans l'aperçu."

#: dorso/onboarding.py:135 dorso/calibration.py:60
msgid "Calibrate"
msgstr "Calibrer"

#: dorso/onboarding.py:141 dorso/calibration.py:65
msgid "Cancel"
msgstr "Annuler"

#: dorso/onboarding.py:160
msgid "All set!"
msgstr "C'est prêt !"

#: dorso/onboarding.py:165
msgid ""
"Dorso is now running in the background.\n"
"\n"
"• <b>Tray icon</b> — real-time posture status\n"
"• <b>Settings</b> — warning mode, color, sensitivity\n"
"• <b>Analytics</b> — daily score and history"
msgstr ""
"Dorso tourne maintenant en arrière-plan.\n"
"\n"
"• <b>Icône système</b> — état de votre posture en temps réel\n"
"• <b>Paramètres</b> — mode d'alerte, couleur, sensibilité\n"
"• <b>Analytiques</b> — score du jour et historique"

#: dorso/onboarding.py:178
msgid "Start"
msgstr "Démarrer"

#: dorso/onboarding.py:252
msgid ""
"<b>Camera not found</b>\n"
"\n"
"Make sure your webcam is plugged in\n"
"and try again."
msgstr ""
"<b>Caméra introuvable</b>\n"
"\n"
"Vérifiez que votre webcam est branchée\n"
"et réessayez."

#: dorso/onboarding.py:265
msgid ""
"<big><b>Calibrating…</b></big>\n"
"Stay still for a few seconds."
msgstr ""
"<big><b>Calibration en cours…</b></big>\n"
"Restez immobile quelques secondes."

#: dorso/onboarding.py:282
msgid ""
"<b>Calibration failed</b>\n"
"\n"
"Make sure you are clearly visible to the camera\n"
"and try again."
msgstr ""
"<b>Calibration échouée</b>\n"
"\n"
"Assurez-vous d'être bien visible par la caméra\n"
"et réessayez."

#: dorso/calibration.py:32
msgid "Dorso — Calibration"
msgstr "Dorso — Calibration"

#: dorso/calibration.py:46
msgid ""
"<big><b>Posture calibration</b></big>\n"
"\n"
"Sit up straight in your best\n"
"posture, then click\n"
"<b>Calibrate</b>."
msgstr ""
"<big><b>Calibration de la posture</b></big>\n"
"\n"
"Asseyez-vous bien droit dans votre\n"
"meilleure posture, puis cliquez sur\n"
"<b>Calibrer</b>."

#: dorso/calibration.py:78
msgid ""
"<big><b>Calibrating…</b></big>\n"
"\n"
"Stay still for a few\n"
"seconds."
msgstr ""
"<big><b>Calibration en cours…</b></big>\n"
"\n"
"Restez immobile pendant quelques\n"
"secondes."

