#: dorso/onboarding.py:68
msgid "Welcome to Dorso"
msgstr "Bienvenido a Dorso"

#: dorso/onboarding.py:73
msgid ""
"Dorso monitors your posture via webcam\n"
"and shows a <b>red glow</b> when you slouch.\n"
"\n"
"The overlay is transparent and doesn't\n"
"interfere with mouse or keyboard."
msgstr ""
"Dorso monitorea tu postura mediante la webcam\n"
"y muestra un <b>resplandor rojo</b> cuando te encorvas.\n"
"\n"
"La superposición es transparente y no\n"
"interfiere con el ratón ni el teclado."

#: dorso/onboarding.py:86
msgid "Get started →"
msgstr "Comenzar →"

#: dorso/onboarding.py:106
msgid "Calibration"
msgstr "Calibración"

#: dorso/onboarding.py:111
msgid ""
"Sit <b>up straight</b> in your best posture.\n"
"Make sure you are visible in the preview."
msgstr ""
"Siéntate <b>bien erguido</b> en tu mejor postura.\n"
"Asegúrate de ser visible en la vista previa."

#: dorso/onboarding.py:135 dorso/calibration.py:60
msgid "Calibrate"
msgstr "Calibrar"

#: dorso/onboarding.py:141 dorso/calibration.py:65
msgid "Cancel"
msgstr "Cancelar"

#: dorso/onboarding.py:160
msgid "All set!"
msgstr "¡Todo listo!"

#: dorso/onboarding.py:165
msgid ""
"Dorso is now running in the background.\n"
"\n"
"• <b>Tray icon</b> — real-time posture status\n"
"• <b>Settings</b> — warning mode, color, sensitivity\n"
"• <b>Analytics</b> — daily score and history"
msgstr ""
"Dorso se está ejecutando en segundo plano.\n"
"\n"
"• <b>Icono de bandeja</b> — estado de tu postura en tiempo real\n"
"• <b>Ajustes</b> — modo de alerta, color, sensibilidad\n"
"• <b>Analíticas</b> — puntuación diaria e historial"

#: dorso/onboarding.py:178
msgid "Start"
msgstr "Iniciar"

#: dorso/onboarding.py:252
msgid ""
"<b>Camera not found</b>\n"
"\n"
"Make sure your webcam is plugged in\n"
"and try again."
msgstr ""
"<b>Cámara no encontrada</b>\n"
"\n"
"Asegúrate de que tu webcam esté conectada\n"
"e inténtalo de nuevo."

#: dorso/onboarding.py:265
msgid ""
"<big><b>Calibrating…</b></big>\n"
"Stay still for a few seconds."
msgstr ""
"<big><b>Calibrando…</b></big>\n"
"No te muevas durante unos segundos."

#: dorso/onboarding.py:282
msgid ""
"<b>Calibration failed</b>\n"
"\n"
"Make sure you are clearly visible to the camera\n"
"and try again."
msgstr ""
"<b>Calibración fallida</b>\n"
"\n"
"Asegúrate de ser claramente visible para la cámara\n"
"e inténtalo de nuevo."

#: dorso/calibration.py:32
msgid "Dorso — Calibration"
msgstr "Dorso — Calibración"

#: dorso/calibration.py:46
msgid ""
"<big><b>Posture calibration</b></big>\n"
"\n"
"Sit up straight in your best\n"
"posture, then click\n"
"<b>Calibrate</b>."
msgstr ""
"<big><b>Calibración de postura</b></big>\n"
"\n"
"Siéntate bien erguido en tu\n"
"mejor postura, luego haz clic en\n"
"<b>Calibrar</b>."

#: dorso/calibration.py:78
msgid ""
"<big><b>Calibrating…</b></big>\n"
"\n"
"Stay still for a few\n"
"seconds."
msgstr ""
"<big><b>Calibrando…</b></big>\n"
"\n"
"No te muevas durante unos\n"
"segundos."

